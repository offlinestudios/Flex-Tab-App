# ─────────────────────────────────────────────────────────────────────────────
# FlexTab .env — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ── Authentication (Supabase) ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional but recommended for server-side auth (avoids RLS restrictions)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
# Required for: profile picture upload, community post media, workout card sharing
#
# How to set up:
#   1. Go to https://dash.cloudflare.com → R2 Object Storage
#   2. Create a bucket (e.g. "flextab-storage")
#   3. Enable "Public Access" on the bucket (R2 → bucket → Settings → Public Access)
#   4. Go to R2 → Manage R2 API Tokens → Create API Token
#      - Permissions: Object Read & Write
#      - Scope: Specific bucket → your bucket name
#   5. Copy the Account ID, Access Key ID, and Secret Access Key below
#
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=flextab-storage
# Public URL for your R2 bucket (from: R2 → bucket → Settings → Public Access → Bucket URL)
# Format: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-your-hash.r2.dev

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
